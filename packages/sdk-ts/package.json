{
  "name": "@grantex/sdk",
  "version": "0.3.3",
  "description": "TypeScript SDK for the Grantex delegated authorization protocol",
  "homepage": "https://grantex.dev",
  "bugs": {
    "url": "https://github.com/mishrasanjeev/grantex/issues"
  },
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./manifests/*": {
      "import": "./dist/manifests/*.js",
      "types": "./dist/manifests/*.d.ts"
    },
    "./manifests": {
      "import": "./dist/manifests/index.js",
      "types": "./dist/manifests/index.d.ts"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "jose": "^5.2.4"
  },
  "overrides": {
    "esbuild": ">=0.25.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@vitest/coverage-v8": "^1.6.1",
    "typescript": "^5.3.3",
    "vitest": "^1.3.1"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "grantex",
    "ai-agents",
    "authorization",
    "oauth",
    "jwt",
    "delegated-auth",
    "sdk",
    "agent-permissions",
    "grant-token",
    "agent-identity",
    "verifiable-credentials",
    "webauthn",
    "fido2",
    "did",
    "sd-jwt",
    "mpp",
    "machine-payments",
    "agent-delegation",
    "revocation",
    "scoped-permissions"
  ],
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/mishrasanjeev/grantex"
  }
}
