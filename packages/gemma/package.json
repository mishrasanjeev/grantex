{
  "name": "@grantex/gemma",
  "version": "0.1.0",
  "description": "Offline authorization adapter for Google Gemma on-device AI agents",
  "homepage": "https://grantex.dev/for/gemma",
  "bugs": {
    "url": "https://github.com/mishrasanjeev/grantex/issues"
  },
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:e2e": "vitest run tests/e2e/",
    "test:watch": "vitest"
  },
  "dependencies": {
    "jose": "^5.2.4",
    "ulid": "^2.3.0"
  },
  "overrides": {
    "esbuild": ">=0.25.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "typescript": "^5.3.3",
    "vitest": "^4.1.2"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "grantex",
    "gemma",
    "offline-auth",
    "ai-agents",
    "authorization",
    "on-device",
    "jwt",
    "audit-log",
    "hash-chain",
    "consent-bundle",
    "edge-ai",
    "google-gemma",
    "agent-permissions",
    "delegated-auth"
  ],
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/mishrasanjeev/grantex"
  }
}
