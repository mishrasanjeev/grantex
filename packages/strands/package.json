{
  "name": "@grantex/strands",
  "version": "0.1.1",
  "description": "Strands Agents SDK integration for the Grantex delegated authorization protocol",
  "homepage": "https://grantex.dev/for/strands",
  "bugs": {
    "url": "https://github.com/mishrasanjeev/grantex/issues"
  },
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "peerDependencies": {
    "@grantex/sdk": ">=0.3.11",
    "@strands-agents/sdk": ">=1.6.0",
    "zod": ">=4.1.12"
  },
  "devDependencies": {
    "@grantex/sdk": "file:../sdk-ts",
    "@strands-agents/sdk": "^1.6.0",
    "@types/node": "^20.11.0",
    "typescript": "^5.3.3",
    "vitest": "^4.1.2",
    "zod": "^4.1.12"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "grantex",
    "strands",
    "strands-agents",
    "ai-agents",
    "authorization",
    "oauth",
    "jwt",
    "agent-tools",
    "scope-enforcement",
    "delegated-auth",
    "agent-permissions"
