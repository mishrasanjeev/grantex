{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "io.github.mishrasanjeev/grantex",
  "description": "OAuth 2.0 for AI agents — scoped delegation tokens, audit trails, and revocation.",
  "repository": {
    "url": "https://github.com/mishrasanjeev/grantex",
    "source": "github"
  },
  "version": "0.1.7",
  "packages": [
    {
      "registryType": "npm",
      "identifier": "@grantex/mcp",
      "version": "0.1.7",
      "transport": {
        "type": "stdio"
      },
      "environmentVariables": [
        {
          "description": "Your Grantex API key",
          "isRequired": true,
          "format": "string",
          "isSecret": true,
          "name": "GRANTEX_API_KEY"
        }
      ]
    }
  ]
}
