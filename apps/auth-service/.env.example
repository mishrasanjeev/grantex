# ─── Required ────────────────────────────────────────────────────────────────
DATABASE_URL=postgres://grantex:grantex@localhost:5432/grantex
REDIS_URL=redis://localhost:6379
JWT_ISSUER=https://grantex.dev

# RSA key (PEM format) for JWT signing — REQUIRED in production
# RSA_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"
# For development only — auto-generates ephemeral key on startup:
AUTO_GENERATE_KEYS=true

# ─── Server ──────────────────────────────────────────────────────────────────
PORT=3001
HOST=0.0.0.0
NODE_ENV=development
LOG_LEVEL=info

# ─── Admin ───────────────────────────────────────────────────────────────────
# ADMIN_API_KEY=your-strong-admin-key

# ─── Seed (development only) ────────────────────────────────────────────────
SEED_API_KEY=dev-api-key-local
# SEED_SANDBOX_KEY=dev-sandbox-key-local

# ─── Stripe Billing ─────────────────────────────────────────────────────────
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# STRIPE_PRICE_PRO=price_...
# STRIPE_PRICE_ENTERPRISE=price_...

# ─── Credential Vault ───────────────────────────────────────────────────────
# AES encryption key: 64 hex chars OR 44 base64 chars
# VAULT_ENCRYPTION_KEY=0123456789abcdef...

# ─── FIDO2 / WebAuthn ───────────────────────────────────────────────────────
FIDO_RP_ID=localhost
FIDO_RP_NAME=Grantex Dev
FIDO_ORIGIN=http://localhost:3001

# ─── DID / Verifiable Credentials ───────────────────────────────────────────
DID_WEB_DOMAIN=grantex.dev
# ED25519_PRIVATE_KEY=... (optional — auto-generates if not set)

# ─── SSO ─────────────────────────────────────────────────────────────────────
# SSO_STATE_SECRET=... (optional — derived from RSA key if not set)

# ─── Policy Backends ────────────────────────────────────────────────────────
# OPA_URL=http://localhost:8181/v1/data/grantex
# OPA_FALLBACK_TO_BUILTIN=true
# CEDAR_URL=http://localhost:8182
# CEDAR_FALLBACK_TO_BUILTIN=true

# ─── Email ───────────────────────────────────────────────────────────────────
# RESEND_API_KEY=re_...
# EMAIL_FROM=noreply@grantex.dev

# ─── Observability ───────────────────────────────────────────────────────────
METRICS_ENABLED=true
USAGE_METERING_ENABLED=true
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
# OTEL_SERVICE_NAME=grantex-auth-service
