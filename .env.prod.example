# =============================================================================
# Grantex — Production Environment Variables
# Copy this file to .env.prod and fill in real values before starting.
# Never commit .env.prod to source control.
# =============================================================================

# -----------------------------------------------------------------------------
# Database (PostgreSQL)
# -----------------------------------------------------------------------------
POSTGRES_USER=grantex
POSTGRES_PASSWORD=change-me-strong-password

# Full connection string used by the auth service.
# Must match POSTGRES_USER / POSTGRES_PASSWORD above.
DATABASE_URL=postgres://grantex:change-me-strong-password@postgres:5432/grantex

# -----------------------------------------------------------------------------
# Redis
# -----------------------------------------------------------------------------
REDIS_PASSWORD=change-me-redis-password

# Full connection string used by the auth service.
# Must include the password set above.
REDIS_URL=redis://:change-me-redis-password@redis:6379

# -----------------------------------------------------------------------------
# Auth service
# -----------------------------------------------------------------------------

# RSA private key (PEM, 2048-bit minimum) used to sign grant tokens.
# Generate with:
#   openssl genrsa -out private.pem 2048
#   awk 'NF {sub(/\r/, ""); printf "%s\\n", $0}' private.pem
# Paste the resulting single-line value here (with literal \n between lines).
RSA_PRIVATE_KEY=-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----

# Issuer claim embedded in every JWT. Should be your public base URL.
JWT_ISSUER=https://your-domain.example.com

# Browser/API base URL embedded in consent links, status-list URLs, and docs.
PUBLIC_BASE_URL=https://your-domain.example.com

# Bind port and host (defaults are fine for Docker)
PORT=3001
HOST=0.0.0.0

# The bundled production Compose topology exposes the auth service only through
# its single Nginx hop. Keep this at 1 for that topology; use an exact proxy
# IP/CIDR allowlist or the verified fixed hop count for custom deployments.
# Set false when the service is not behind a trusted proxy.
TRUST_PROXY=1

# 32-byte hex key for encrypting vault credentials at rest.
# Generate with: openssl rand -hex 32
VAULT_ENCRYPTION_KEY=change-me-64-hex-characters

# Admin API bearer token for /v1/admin/* routes.
# Generate with: openssl rand -base64 48
ADMIN_API_KEY=change-me-admin-token

# Metrics are authenticated in production. Prometheus must send:
# Authorization: Bearer <METRICS_API_KEY>
METRICS_ENABLED=true
METRICS_REQUIRE_AUTH=true
METRICS_API_KEY=change-me-metrics-token

# Production outbound URL policy. Keep these false unless a private IdP or
# internal webhook target is explicitly approved and network-isolated.
SSO_ALLOW_INSECURE_URLS=false
SSO_ALLOW_PRIVATE_HOSTS=false
WEBHOOK_ALLOW_INSECURE_URLS=false
WEBHOOK_ALLOW_PRIVATE_HOSTS=false

# LDAP TLS certificate validation. Keep true in production.
LDAP_TLS_REJECT_UNAUTHORIZED=true

# CORS browser origins, comma-separated.
CORS_ALLOWED_ORIGINS=https://your-domain.example.com,https://portal.your-domain.example.com

# -----------------------------------------------------------------------------
# Stripe billing (optional — comment out to disable billing endpoints)
# -----------------------------------------------------------------------------
# STRIPE_SECRET_KEY=sk_live_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# STRIPE_PRICE_PRO=price_...
# STRIPE_PRICE_ENTERPRISE=price_...
